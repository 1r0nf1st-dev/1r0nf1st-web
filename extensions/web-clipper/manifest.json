{
  "manifest_version": 3,
  "name": "1r0nf1st Notes Clipper (1r0nf1st only)",
  "version": "1.0.0",
  "description": "Save web pages to 1r0nf1st Notes. Not in Chrome Web Store—install from project.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  }
}
